# SmartMall Network Automation — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# GNS3 VM Connection
GNS3_HOST=your_gns3_vm_ip
GNS3_PORT=80
GNS3_USER=gns3
GNS3_PASS=gns3

# GNS3 Project Name
GNS3_PROJECT=SmartMall_x

# Cisco Device Credentials
CISCO_SECRET=cisco
CISCO_PASSWORD=

# AI API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
